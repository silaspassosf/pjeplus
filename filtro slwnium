// ==UserScript==
// @name         PJe TRT2 - Automatizar com temporização e ordenação por Prazo
// @namespace    http://tampermonkey.net/
// @version      2.3
// @description  Automatiza seleção de livres, xs em lote, ordena por Prazo e seleciona não livres (logs no console)
// @match        https://pje.trt2.jus.br/pjekz/painel/global/8/lista-processos*
// @match        https://pje.trt2.jus.br/pjekz/painel/movimentacao-lote*
// @grant        none
// ==/UserScript==

(function() {
    'use strict';

    async function esperar(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }

    async function executarTudo() {
        try {
            // 1. Clicar Prazo1
            const btn = document.getElementById('maisPje_filtrofavorito_Prazo1');
            if (!btn) { console.log('Botão Prazo1 não encontrado!'); return; }
            btn.click();
            console.log('Clique Prazo1');
            await esperar(7000); // 7 segundos

            // 2. Selecionar livres
            let selecionados = 0;
            const linhas = Array.from(document.querySelectorAll('tr.cdk-drag'));
            for (const linha of linhas) {
                const prazo = linha.querySelector('td:nth-child(9) time');
                const prazoVazio = !prazo || !prazo.textContent.trim();
                const hasComment = linha.querySelector('i.fa-comment') !== null;
                const input = linha.querySelector('input[matinput]');
                const campoP = input && input.value && input.value.trim();
                const temLupa = linha.querySelector('td:nth-child(3) i.fa-search') !== null;
                if (prazoVazio && !hasComment && !campoP && !temLupa) {
                    const checkbox = linha.querySelector('mat-checkbox input[type="checkbox"]');
                    if (checkbox && !checkbox.checked) {
                        checkbox.click();
                        linha.style.backgroundColor = "#ffccd2";
                        selecionados++;
                    }
                }
            }
            console.log('Selecionados livres:', selecionados);
            await esperar(5000); // 5 segundos

            // 3. Tag verde
            let tagVerde = document.querySelector('i.fa.fa-tag.icone.texto-verde');
            if (!tagVerde) tagVerde = Array.from(document.querySelectorAll('button,span')).find(e => e.innerHTML.includes('fa-tag') && e.innerHTML.includes('texto-verde'));
            if (!tagVerde) { console.log('Ícone/tag verde não encontrado!'); return; }
            tagVerde.click();
            console.log('Clique tag verde');
            await esperar(1000);

            // 4. Atividade (xs em lote)
            await xsLote();

            // 5. Preencher e salvar
            const inputObs = document.querySelector('textarea[formcontrolname="observacao"]');
            if (inputObs) {
                inputObs.value = 'xs';
                inputObs.dispatchEvent(new Event('input', { bubbles: true }));
            }
            const inputDias = document.querySelector('input[formcontrolname="dias"]');
            if (inputDias) {
                inputDias.value = '';
                inputDias.dispatchEvent(new Event('input', { bubbles: true }));
            }
            const btnSalvar = document.querySelector('button[type="submit"].mat-primary');
            if (btnSalvar) {
                btnSalvar.click();
                console.log('Clique salvar');
                await esperar(1200);
                console.log('Atividade em lote registrada com observação "xs"!');
            }

            // 6. Aguarda 5s antes de ordenar por Prazo
            await esperar(5000);
            console.log('Aguardou 5s após xs, agora vai clicar em Prazo');

            // 7. Clicar no header "Prazo"
            const headerPrazo = Array.from(document.querySelectorAll('div[role="column"]')).find(div => div.textContent.trim().toLowerCase() === 'prazo');
            if (headerPrazo) {
                headerPrazo.click();
                console.log('Clique header Prazo');
            } else {
                console.log('Header Prazo não encontrado!');
                return;
            }
            await esperar(3000);

            // 8. Selecionar até 20 "não livres"
            let selecionadosNaoLivres = 0;
            const linhasAtualizadas = Array.from(document.querySelectorAll('tr.cdk-drag'));
            for (const linha of linhasAtualizadas) {
                const prazo = linha.querySelector('td:nth-child(9) time');
                const prazoVazio = !prazo || !prazo.textContent.trim();
                const hasComment = linha.querySelector('i.fa-comment') !== null;
                const input = linha.querySelector('input[matinput]');
                const campoP = input && input.value && input.value.trim();
                const temLupa = linha.querySelector('td:nth-child(3) i.fa-search') !== null;
                const checkbox = linha.querySelector('mat-checkbox input[type="checkbox"]');
                if ((!prazoVazio || hasComment || campoP || temLupa) && checkbox && !checkbox.checked) {
                    checkbox.click();
                    linha.style.backgroundColor = "#d2eaff";
                    selecionadosNaoLivres++;
                    if (selecionadosNaoLivres >= 20) break;
                }
            }
            console.log('Selecionados não livres:', selecionadosNaoLivres);
            await esperar(3000);

            // 9. Chama movimentação em lote após selecionar não livres
            await movlote();
        } catch (e) {
            console.log('Erro no fluxo: ' + e);
            console.error(e);
        }
    }

    // Função para registrar xs em lote
    async function xsLote() {
        try {
            // 1. Clicar no botão "Atividade" do menu
            let btnAtiv = Array.from(document.querySelectorAll('button[mat-menu-item],button.mat-menu-item,span.mat-menu-item,button[aria-label],span[aria-label]'));
            btnAtiv = btnAtiv.find(b => b.innerText && b.innerText.trim().toLowerCase() === 'atividade');
            if (!btnAtiv) btnAtiv = Array.from(document.querySelectorAll('button,span')).find(b => b.innerText && b.innerText.trim().toLowerCase() === 'atividade');
            if (!btnAtiv) { console.log('Botão de menu "Atividade" não encontrado!'); return; }
            btnAtiv.click();
            console.log('Clique Atividade (xs em lote)');
            await esperar(1000);

            // 2. Preencher observação com "xs"
            const inputObs = document.querySelector('textarea[formcontrolname="observacao"]');
            if (inputObs) {
                inputObs.value = 'xs';
                inputObs.dispatchEvent(new Event('input', { bubbles: true }));
                inputObs.focus();
                inputObs.setSelectionRange(inputObs.value.length, inputObs.value.length);
                // Simula digitação para garantir evento
                inputObs.dispatchEvent(new KeyboardEvent('keydown', { key: 'x', bubbles: true }));
                inputObs.dispatchEvent(new KeyboardEvent('keyup', { key: 's', bubbles: true }));
            }
            // Tenta enviar TAB
            if (inputObs) inputObs.dispatchEvent(new KeyboardEvent('keydown', { key: 'Tab', code: 'Tab', bubbles: true }));

            // 3. Clicar em salvar
            const btnSalvar = document.querySelector('button[type="submit"].mat-primary');
            if (btnSalvar) {
                btnSalvar.click();
                console.log('Clique salvar (xs em lote)');
                await esperar(1200);
                console.log('Atividade em lote registrada com observação "xs"!');
            }
        } catch (e) {
            console.log('Erro no xsLote: ' + e);
            console.error(e);
        }
    }

    // Função para movimentação em lote "Cumprimento de providências"
    async function movlote() {
        try {
            console.log('Iniciando movlote...');
            await esperar(2000); // Aguarda 2s
            const iconeMaleta = document.querySelector('i.fa-suitcase, .fa.fa-suitcase');
            if (iconeMaleta) {
                iconeMaleta.click();
                console.log('Clique ícone maleta');
            }

            // Aguarda a navegação para a URL de movimentação em lote
            let tentativas = 0;
            while (window.location.href.indexOf('movimentacao-lote') === -1 && tentativas < 30) {
                await esperar(300);
                tentativas++;
            }
            if (window.location.href.indexOf('movimentacao-lote') === -1) {
                console.log('Não navegou para a tela de movimentação em lote!');
                return;
            }
            console.log('Navegou para movimentacao-lote');
            await esperar(1200);

            // 1. Clicar na seta do mat-select de tarefa destino única
            let setaSelect = document.querySelector('div.mat-select-arrow-wrapper');
            if (!setaSelect) {
                console.log('Seta do mat-select "Tarefa destino única" não encontrada!');
                return;
            }
            setaSelect.click();
            console.log('Clique seta mat-select tarefa destino única');
            await esperar(1000);

            // 2. Clicar na opção "Cumprimento de providências"
            let opcoes = Array.from(document.querySelectorAll('mat-option'));
            let opcaoMov = opcoes.find(b => b.innerText && b.innerText.trim().toLowerCase().includes('cumprimento de provid'));
            if (!opcaoMov) {
                // Tenta buscar novamente após aguardar
                await esperar(1000);
                opcoes = Array.from(document.querySelectorAll('mat-option'));
                opcaoMov = opcoes.find(b => b.innerText && b.innerText.trim().toLowerCase().includes('cumprimento de provid'));
            }
            if (!opcaoMov) {
                console.log('Opção "Cumprimento de providências" não encontrada!');
                return;
            }
            opcaoMov.click();
            console.log('Clique "Cumprimento de providências"');
            await esperar(2000);

            // 3. Clica em "Movimentar processos"
            const btnMov = Array.from(document.querySelectorAll('button,span')).find(b => b.innerText && b.innerText.trim().toLowerCase().includes('movimentar processos'));
            if (!btnMov) { console.log('Botão "Movimentar processos" não encontrado!'); return; }
            btnMov.click();
            console.log('Clique "Movimentar processos"');
            await esperar(3000);
            // 4. Envia ALT+seta direita
            const evt = new KeyboardEvent('keydown', { key: 'ArrowRight', code: 'ArrowRight', altKey: true, bubbles: true });
            document.dispatchEvent(evt);
            console.log('Enviado ALT+seta direita');

            // 4. Voltar para a página anterior (lista de processos)
            await esperar(1500);
            window.history.back();
            console.log('Executado window.history.back() para retornar à lista de processos');
            // Alternativa: forçar navegação se não voltar após 3s
            setTimeout(function() {
                if (window.location.href.indexOf('lista-processos') === -1) {
                    window.location.href = 'https://pje.trt2.jus.br/pjekz/painel/global/8/lista-processos';
                    console.log('Forçado retorno para lista de processos');
                }
            }, 3500);
        } catch (e) {
            console.log('Erro no movlote: ' + e);
            console.error(e);
        }
    }
    // Criar botão simples
    function criarBotao() {
        // Verificar se estamos na URL correta antes de criar o botão
        if (!window.location.href.match(/\/painel\/global\/8\/lista-processos(\?|$)/)) {
            console.log('Script não executado: não está na página de lista de processos');
            return;
        }
        // Verificar se o botão já existe
        if (document.getElementById('automatizar-btn')) {
            // Se o botão existe mas não está no body, reinserir
            if (!document.body.contains(document.getElementById('automatizar-btn'))) {
                document.body.appendChild(document.getElementById('automatizar-btn'));
            }
            return;
        }
        const btn = document.createElement('button');
        btn.id = 'automatizar-btn';
        btn.textContent = 'Automatizar Seleção e Atividade em Lote (Temporização)';
        btn.style.position = 'fixed';
        btn.style.top = '10px';
        btn.style.right = '10px';
        btn.style.zIndex = '9999';
        btn.style.background = '#4caf50';
        btn.style.color = '#fff';
        btn.style.padding = '10px 16px';
        btn.style.border = 'none';
        btn.style.borderRadius = '6px';
        btn.style.fontSize = '16px';
        btn.style.cursor = 'pointer';
        btn.style.fontWeight = 'bold';
        btn.style.boxShadow = '0 2px 5px rgba(0,0,0,0.2)';
        btn.onclick = executarTudo;
        // Aguardar o body estar disponível
        const adicionarBotao = () => {
            if (document.body) {
                document.body.appendChild(btn);
                console.log('Botão automatizar criado com sucesso!');
            } else {
                setTimeout(adicionarBotao, 100);
            }
        };
        adicionarBotao();
    }

    // Múltiplas estratégias de inicialização para garantir que o botão apareça
    function inicializar() {
        // Só injeta se for a URL correta
        if (window.location.href.match(/\/painel\/global\/8\/lista-processos(\?|$)/)) {
            criarBotao();
        }
    }

    // 1. Se DOM já carregado
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
        inicializar();
    }

    // 2. Aguardar DOMContentLoaded
    document.addEventListener('DOMContentLoaded', inicializar);

    // 3. Aguardar window.load
    window.addEventListener('load', inicializar);

    // 4. Timeout como fallback
    setTimeout(inicializar, 1000);

    // 5. Observar mudanças na URL (para SPAs)
    let currentUrl = window.location.href;
    const observer = new MutationObserver(() => {
        if (currentUrl !== window.location.href) {
            currentUrl = window.location.href;
            setTimeout(inicializar, 500);
        }
        // Se o botão sumiu, reinserir
        if (window.location.href.match(/\/painel\/global\/8\/lista-processos(\?|$)/) && !document.getElementById('automatizar-btn')) {
            criarBotao();
        }
    });
    observer.observe(document.body || document.documentElement, {
        childList: true,
        subtree: true
    });
})();