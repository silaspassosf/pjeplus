                                if safe_click(driver, opcao, 'click'):
                                    if log:
                                        print("[SISBAJUD] ✅ Tipo de crédito 'Geral' selecionado")
                                    break
                        except Exception:
                            continue

                    # Delay antes do próximo campo
                    time.sleep('form_fill', base_delay=2.0)

                    # ===== PREENCHIMENTO BANCO E AGÊNCIA - OTIMIZADO COMO GIGS.PY =====
                    if log:
                        print("[SISBAJUD] [OTIMIZADO] Usando JavaScript puro para reduzir requisições...")
                    
                    # SCRIPT ÚNICO - reproduz exatamente o gigs.py sem polling excessivo
                    script_otimizado = """
                    // Funções exatas do gigs.py
                    function esperarElemento(seletor, timeout = 5000) {
                        return new Promise(resolve => {
                            let elemento = document.querySelector(seletor);
                            let disabled = (elemento && elemento.disabled === undefined) ? false : elemento.disabled;
                            if (elemento && !disabled) {
                                resolve(elemento);
                                return;
                            } else {
                                let observer = new MutationObserver(mutations => {
                                    let elemento_esperado = document.querySelector(seletor);
                                    let disabled = (elemento_esperado && elemento_esperado.disabled === undefined) ? false : elemento_esperado.disabled;
                                    if (elemento_esperado && !disabled) {
                                        observer.disconnect();
                                        resolve(elemento_esperado);
                                        return;
                                    }
                                });
                                
                                observer.observe(document.body, { childList: true, subtree: true });
                                setTimeout(function() { 
                                    observer.disconnect(); 
                                    resolve(null); 
                                }, timeout);
                            }
                        });
                    }
                    
                    function triggerEvent(el, type) {
                        if ('createEvent' in document) {        
                            let e = document.createEvent('HTMLEvents');
                            e.initEvent(type, false, true);
                            el.dispatchEvent(e);
                        }
                    }
                    
                    async function executarBancoAgencia() {
                        try {
                            let msgs = [];
                            
                            // 1. BANCO - exato como gigs.py
                            msgs.push('Aguardando campo banco...');
                            let bancoInput = await esperarElemento('input[formcontrolname="instituicaoFinanceiraPorCategoria"]');
                            if (!bancoInput) {
                                return {sucesso: false, msg: 'Campo banco não encontrado'};
                            }
                            
                            // Clicar no parentElement.parentElement
                            msgs.push('Clicando no campo banco...');
                            bancoInput.parentElement.parentElement.click();
                            
                            // Aguardar dropdown abrir
                            await new Promise(resolve => setTimeout(resolve, 2000));
                            
                            // Buscar opção 00001
                            let opcoes = document.querySelectorAll('mat-option[role="option"]');
                            let bancoOK = false;
                            for (let opcao of opcoes) {
                                let texto = opcao.textContent || '';
                                if (texto.includes('00001') || texto.toUpperCase().includes('BANCO DO BRASIL') || texto.toUpperCase().includes('BCO DO BRASIL')) {
                                    msgs.push('Banco encontrado: ' + texto.substring(0, 50));
                                    opcao.click();
                                    bancoOK = true;
                                    break;
                                }
                            }
                            
                            if (!bancoOK) {
                                return {sucesso: false, msg: 'Banco 00001 não encontrado'};
                            }
                            
                            // Aguardar após banco
                            await new Promise(resolve => setTimeout(resolve, 2000));
                            
                            // 2. AGÊNCIA - exato como gigs.py (sem clique)
                            msgs.push('Aguardando campo agencia...');
                            let agenciaInput = await esperarElemento('input[formcontrolname="agencia"]');
                            if (!agenciaInput) {
                                return {sucesso: false, msg: 'Campo agencia não encontrado'};
                            }
                            
                            // Sequência exata: focus -> value -> triggerEvent -> blur
                            msgs.push('Preenchendo agencia 5905...');
                            agenciaInput.focus();
                            agenciaInput.value = '5905';
                            triggerEvent(agenciaInput, 'input');
                            agenciaInput.blur();
                            
                            return {sucesso: true, msg: 'Concluído', detalhes: msgs};
                            
                        } catch(e) {
                            return {sucesso: false, msg: 'Erro: ' + e.message};
                        }
                    }
                    
                    return executarBancoAgencia();
                    """
                    
                    # Executar script único (reduz drasticamente as requisições)
                    resultado = None
                    try:
                        resultado = driver.execute_script(script_otimizado)
                        if log and resultado:
                            print(f"[SISBAJUD] [OTIMIZADO] Resultado: {resultado.get('msg', 'N/A')}")
                            if resultado.get('detalhes'):
                                for msg in resultado['detalhes']:
                                    print(f"[SISBAJUD] [JS] {msg}")
                    except Exception as e:
                        if log:
                            print(f"[SISBAJUD] ❌ Erro no script otimizado: {e}")
                        resultado = {'sucesso': False, 'msg': str(e)}
                    
                    if resultado and resultado.get('sucesso'):
                        if log:
