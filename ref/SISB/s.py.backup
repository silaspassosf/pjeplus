def aplicar_acao_por_fluxo(driver, tipo_fluxo, ordem_sequencial=None, log=True):
    """
    Wrapper reutilizável para selecionar a ação correta na página /desdobrar.
    VERSÃO DIRECT: Estratégia simplificada e mais robusta do gigs.py
    Prioriza 'Transferir valor' e 'Desbloquear valor' com busca direta.
    Retorna True se a ação foi selecionada com sucesso.
    """
    try:
        if log:
            print(f"[SISBAJUD] 🎯 Selecionando ação para fluxo {tipo_fluxo}")

        # Determinar ações alvo baseado no tipo de fluxo
        if tipo_fluxo == 'POSITIVO':
            acao_primaria = 'Transferir valor'
            acao_secundaria = 'Desbloquear valor'
        else:  # DESBLOQUEIO
            acao_primaria = 'Desbloquear valor'
            acao_secundaria = 'Transferir valor'

        # Buscar todos os dropdowns de ação (estratégia simplificada)
        selects = driver.find_elements(By.CSS_SELECTOR, "mat-select")
        
        if not selects:
            if log:
                print('[SISBAJUD] ❌ Nenhum mat-select encontrado')
            return False

        # Tentar cada dropdown
        for idx, sel in enumerate(selects):
            try:
                # Clicar diretamente (sem delays desnecessários)
                sel.click()
                time.sleep(0.4)  # Mínimo delay para opções aparecerem
                
                # Buscar opções
                try:
                    opcoes = WebDriverWait(driver, 2.0).until(
                        EC.presence_of_all_elements_located((By.CSS_SELECTOR, "mat-option[role='option']"))
                    )
                except Exception:
                    if log:
                        print(f"[SISBAJUD] ⚠️ Opções não aparecerem no dropdown #{idx+1}")
                    # Fechar e prosseguir
                    try:
                        ActionChains(driver).send_keys(Keys.ESCAPE).perform()
                    except:
                        pass
                    continue

                if not opcoes:
                    continue

                # Estratégia de busca direta como em gigs.py:
                # 1. Tentar acao primária
                # 2. Se não encontrar, tentar acao secundária
                # 3. Se ainda não encontrar, pular para próximo dropdown
                
                acao_selecionada = False
                
                # Buscar pela ação primária
                for opcao in opcoes:
                    try:
                        texto = opcao.text.strip()
                        if texto == acao_primaria:
                            opcao.click()
                            if log:
                                print(f"[SISBAJUD] ✅ '{acao_primaria}' selecionada")
                            return True
                    except Exception:
                        pass
                
                # Se não encontrou primária, buscar pela secundária
                for opcao in opcoes:
                    try:
                        texto = opcao.text.strip()
                        if texto == acao_secundaria:
                            opcao.click()
                            if log:
                                print(f"[SISBAJUD] ✅ '{acao_secundaria}' selecionada (fallback)")
                            return True
                    except Exception:
                        pass
                
                # Nenhuma encontrada neste dropdown, fechar e tentar próximo
                try:
                    ActionChains(driver).send_keys(Keys.ESCAPE).perform()
                    time.sleep(0.2)
                except:
                    pass
                        
            except Exception as e:
                if log:
                    print(f"[SISBAJUD] ⚠️ Erro no dropdown #{idx+1}: {e}")
                try:
                    ActionChains(driver).send_keys(Keys.ESCAPE).perform()
                except:
                    pass
                continue

        # Se chegou aqui, não conseguiu selecionar
        if log:
            print(f"[SISBAJUD] ❌ Ação não encontrada em nenhum dropdown")
        return False

    except Exception as e:
        if log:
            print(f"[SISBAJUD] ❌ Erro em aplicar_acao_por_fluxo: {e}")
        return False

def cadastrar_reu_sisbajud(driver, reu, config_sisbajud):
    """
    Implementa a função cadastro() do código otimizado
    Com tratamento de CNPJ raiz e delays específicos
    """
    try:
        # Aguardar campo CPF/CNPJ
        try:
            elemento_cpf = WebDriverWait(driver, 8).until(
                EC.element_to_be_clickable((By.CSS_SELECTOR, 'input[placeholder="CPF/CNPJ do réu/executado"], input[placeholder="CPF/CNPJ da pessoa pesquisada"]'))
            )
        except Exception as e:
            print(f'[SISBAJUD] ❌ Campo CPF/CNPJ não encontrado: {e}')
            return False
        
        try:
            botao_adicionar = WebDriverWait(driver, 10).until(
                EC.presence_of_element_located((By.CSS_SELECTOR, 'button[class*="btn-adicionar"]'))
            )
        except:
            botao_adicionar = None
        
        if not elemento_cpf or not botao_adicionar:
            return False
        
        # Focar via JavaScript como no gigs.py (corrigido)
        driver.execute_script("arguments[0].focus();", elemento_cpf)
        
        # Lógica CNPJ raiz do código otimizado
        documento = reu.get('cpfcnpj', '').replace('.', '').replace('-', '').replace('/', '')
        
        # Se é CNPJ (>14 chars) e config permite CNPJ raiz
        if len(documento) > 14 and config_sisbajud.get('cnpjRaiz', '').lower() == 'sim':
            documento = documento[:10]  # Primeiros 10 dígitos
        
        print(f'[SISBAJUD]             Preenchendo: {documento}')
        
        elemento_cpf.clear()
        elemento_cpf.send_keys(documento)
        trigger_event(elemento_cpf, 'input')
        
        # Delay específico do código otimizado
        time.sleep(0.8)
        
        # Verificar se precisa corrigir (lógica complexa do código otimizado)
        valor_atual = elemento_cpf.get_attribute('value')
        if (len(documento) < 15 and len(valor_atual) == 10) or len(valor_atual) != len(documento):
            # Corrigir valor
            elemento_cpf.clear()
            elemento_cpf.send_keys(documento)
            trigger_event(elemento_cpf, 'input')
        
        # Aguardar estabilidade e clicar
        time.sleep(0.8)
        trigger_event(botao_adicionar, 'click')
        
        return True
        
    except Exception as e:
        print(f'[SISBAJUD] Erro ao cadastrar réu: {e}')
        return False

