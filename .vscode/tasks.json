{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Debug Visual - M1",
            "type": "shell",
            "command": "python",
            "args": [
                "exemplo_debug_visual.py"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "new",
                "showReuseMessage": true,
                "clear": false
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Verificar Sintaxe Python",
            "type": "shell",
            "command": "python",
            "args": [
                "-m",
                "py_compile",
                "${file}"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                {
                    "owner": "python",
                    "source": "py_compile",
                    "fileLocation": "absolute",
                    "pattern": {
                        "regexp": "File \"(.*)\", line (\\d+)",
                        "file": 1,
                        "line": 2
                    }
                }
            ]
        },
        {
            "label": "Verificar Sintaxe - Arquivo Atual",
            "type": "shell",
            "command": "python",
            "args": [
                "-m",
                "py_compile",
                "${file}"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "new",
                "showReuseMessage": false,
                "clear": true
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$python"
        },
        {
            "label": "Debug Completo (Executar + Abrir Relatório)",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Debug Visual - M1",
                "Abrir Relatório Debug"
            ]
        }
    ]
}