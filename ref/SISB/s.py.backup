def registrar_erro_minuta(processo: str, erro: Exception, modulo: str = "minuta_bloqueio", continuar: bool = True) -> bool:
    """
    Registra erro em minuta usando core_errors (Etapa 5)
    Permite continuar processando sem interromper
    
    Args:
        processo: Número do processo
        erro: Exception capturada
        modulo: Nome do módulo onde ocorreu
        continuar: Se True, apenas registra; se False, levanta exceção
    
    Returns:
        True se erro foi registrado, False caso contrário
    """
    if not USAR_CORE_MODULES:
        print(f'[SISBAJUD] ⚠️ core_errors não disponível, registrando localmente')
        print(f'[SISBAJUD] ❌ Erro em {modulo}: {erro}')
        return False
    
    try:
        coletor_erros.registrar_erro(processo, erro, modulo)
        print(f'[SISBAJUD] 📋 Erro registrado no collector (continuando...)')
        
        if continuar:
            return True
        else:
            raise erro
    except Exception as e:
        print(f'[SISBAJUD] ❌ Erro ao registrar no collector: {e}')
        return False

def criar_fluent_driver(driver, timeout: int = 10):
    """
    Factory para DriverFluent (Etapa 6 - core_fluent)
    Cria interface fluente para method chaining
    
    Args:
        driver: WebDriver Selenium
        timeout: Timeout padrão para esperas
    
    Returns:
        DriverFluent instance ou wrapper compatível
    
    Exemplo:
        fluent = criar_fluent_driver(driver)
        fluent.find(By.ID, 'campo1').send_keys('valor').find(By.ID, 'botao').click()
    """
    if not USAR_CORE_MODULES:
        print(f'[SISBAJUD] ⚠️ core_fluent não disponível, retornando fallback')
        return None
    
    try:
        # DriverFluent REMOVIDO - Use JavaScript consolidado
        fluent = None
        print(f'[SISBAJUD] ⚠️ DriverFluent removido (use JavaScript consolidado)')
        return fluent
    except Exception as e:
        print(f'[SISBAJUD] ❌ Erro ao criar interface fluente: {e}')
        return None

def preencher_formulario_fluent(driver, campos_dict: dict) -> bool:
    """
    Preenche múltiplos campos de formulário usando DriverFluent (Etapa 6)
    
    Args:
        driver: WebDriver Selenium
        campos_dict: Dicionário {seletor_css: valor, ...}
    
    Returns:
        True se todos preenchidos, False se algum erro
    
    Exemplo:
        campos = {
            'input[placeholder*="CPF"]': '12345678901',
            'input[placeholder*="Nome"]': 'João Silva',
        }
        preencher_formulario_fluent(driver, campos)
    """
    if not USAR_CORE_MODULES:
        print(f'[SISBAJUD] ⚠️ core_fluent não disponível')
        return False
    
    try:
        fluent = criar_fluent_driver(driver)
        if not fluent:
            return False
        
        print(f'[SISBAJUD] 📝 Preenchendo {len(campos_dict)} campos com DriverFluent...')
        
        for seletor, valor in campos_dict.items():
            try:
                fluent.find(By.CSS_SELECTOR, seletor).clear().send_keys(valor)
                print(f'[SISBAJUD] ✅ Campo preenchido: {seletor}')
            except Exception as e:
                print(f'[SISBAJUD] ⚠️ Erro ao preencher {seletor}: {e}')
                continue
        
        print(f'[SISBAJUD] ✅ Formulário preenchido com sucesso (method chaining)')
        return True
        
    except Exception as e:
        print(f'[SISBAJUD] ❌ Erro em preencher_formulario_fluent: {e}')
        return False


def escolher_opcao_sisbajud(driver, seletor, valor):
    """
    Seleciona opção OTIMIZADA usando JavaScript (como gigs.py) - SEM POLLING
    """
    script_selecionar = f"""
    async function selecionarOpcao() {{
        try {{
            // 1. Aguardar opções aparecerem
            function esperarOpcoes(timeout = 5000) {{
                return new Promise(resolve => {{
                    let opcoes = document.querySelectorAll('mat-option[role="option"]');
                    if (opcoes.length > 0) {{
                        resolve(opcoes);
                        return;
                    }}
                    
                    let observer = new MutationObserver(mutations => {{
                        let opcoes_encontradas = document.querySelectorAll('mat-option[role="option"]');
                        if (opcoes_encontradas.length > 0) {{
                            observer.disconnect();
                            resolve(opcoes_encontradas);
                            return;
                        }}
                    }});
                    
                    observer.observe(document.body, {{ childList: true, subtree: true }});
                    setTimeout(function() {{ 
                        observer.disconnect(); 
                        resolve([]); 
                    }}, timeout);
                }});
            }}
            
            // 2. Aguardar e buscar opção
            let opcoes = await esperarOpcoes();
            if (opcoes.length === 0) {{
                return {{sucesso: false, msg: 'Nenhuma opção encontrada'}};
            }}
            
            // 3. Buscar opção com valor
            let opcaoEncontrada = null;
            for (let opcao of opcoes) {{
                let texto = opcao.textContent || '';
                if (texto.includes('{valor}') || texto.toUpperCase().includes('{valor.upper()}')) {{
                    opcaoEncontrada = opcao;
                    break;
                }}
            }}
            
            if (!opcaoEncontrada) {{
                return {{sucesso: false, msg: 'Opção "{valor}" não encontrada'}};
            }}
            
            // 4. Clicar na opção
            opcaoEncontrada.click();
            return {{sucesso: true, msg: 'Opção "{valor}" selecionada', texto: opcaoEncontrada.textContent}};
            
        }} catch(e) {{
            return {{sucesso: false, msg: 'Erro: ' + e.message}};
        }}
    }}
    
    return selecionarOpcao();
    """
    
    try:
        # Executa JavaScript otimizado
        resultado = driver.execute_script(script_selecionar)
        
        if resultado and resultado.get('sucesso'):
            print(f'[SISBAJUD] ✅ Opção selecionada (JS otimizado): {resultado.get("texto", valor)}')
            return True
        else:
            msg_erro = resultado.get('msg') if resultado else 'Erro desconhecido'
            print(f'[SISBAJUD] ❌ Falha na seleção: {msg_erro}')
            return False
        
        # Fallback: lógica original se core_selectors não disponível
        print(f'[SISBAJUD] 📍 Modo fallback: buscando opção {valor}')
        
        # Buscar o campo com retry
        campo = None
        for tentativa in range(8):
            try:
                if USAR_CORE_MODULES:
                    smart_sleep('default')
                else:
                    time.sleep(0.5)
                campo = driver.find_element(By.CSS_SELECTOR, seletor)
                break
            except Exception:
                print(f'[SISBAJUD] Tentativa {tentativa + 1}/8 para encontrar campo {seletor}')
        
        if not campo:
            print(f'[SISBAJUD] ❌ Campo não encontrado: {seletor}')
            return False

        # Clicar no campo com segurança
        if not safe_click(driver, campo, 'click'):
            # Tentar via JavaScript como fallback
            if not safe_execute_script(driver, 'arguments[0].click();', 'click', campo):
                print(f'[SISBAJUD] ❌ Não foi possível clicar no campo: {seletor}')
                return False

        # Aguardar opções aparecerem
        print(f'[SISBAJUD] Aguardando opções para valor: {valor}')
        opcoes = aguardar_opcoes_aparecerem(driver, 'mat-option[role="option"], option, span.mat-option-text', 
                                          intervalo_ms=200, max_tentativas=20)
        
        if not opcoes:
            print(f'[SISBAJUD] ❌ Nenhuma opção encontrada para: {valor}')
            return False

        # Procurar correspondência
        print(f'[SISBAJUD] Procurando entre {len(opcoes)} opções...')
        for i, opc in enumerate(opcoes):
            try:
                texto_opcao = opc.text.strip()
                
                if valor.lower() in texto_opcao.lower():
                    print(f'[SISBAJUD] ✅ Opção encontrada: "{texto_opcao}"')
                    
                    # Tentar clicar na opção
                    if safe_click(driver, opc, 'click'):
                        print(f'[SISBAJUD] ✅ Opção selecionada com sucesso')
                        return True
                    else:
                        # Fallback via JavaScript
                        if safe_execute_script(driver, 'arguments[0].click();', 'click', opc):
                            print(f'[SISBAJUD] ✅ Opção selecionada via JavaScript')
                            return True
                            
            except Exception as e:
                print(f'[SISBAJUD] ⚠️ Erro ao processar opção {i + 1}: {e}')
                continue

        print(f'[SISBAJUD] ❌ Nenhuma opção correspondente encontrada para: {valor}')
        return False
        
    except Exception as e:
        print(f'[SISBAJUD] ❌ Erro geral em escolher_opcao_sisbajud: {e}')
        SISBAJUD_STATS['consecutive_errors'] += 1
        return False

def escolher_opcao_core(driver, valor: str, debug: bool = False) -> bool:
    """
    Wrapper direto para escolher_opcao_inteligente (Etapa 3 - core_selectors)
    Tenta múltiplos seletores em ordem de performance
    
    Args:
        driver: WebDriver Selenium
        valor: Valor a procurar (texto, id, etc)
        debug: Ativa logging detalhado
    
    Returns:
        True se encontrou e clicou, False caso contrário
    """
    if not USAR_CORE_MODULES:
        print(f'[SISBAJUD] ⚠️ core_selectors não disponível, use escolher_opcao_sisbajud()')
        return False
    
    try:
        print(f'[SISBAJUD] 🔍 Usando core_selectors para: {valor}')
        sucesso = escolher_opcao_inteligente(driver, valor, debug=debug)
        
        if sucesso:
            print(f'[SISBAJUD] ✅ core_selectors funcionou para: {valor}')
            SISBAJUD_STATS['consecutive_errors'] = 0  # Reset erro
        else:
            print(f'[SISBAJUD] ❌ core_selectors falhou para: {valor}')
        
        return sucesso
    except Exception as e:
        print(f'[SISBAJUD] ❌ Erro em escolher_opcao_core: {e}')
        SISBAJUD_STATS['consecutive_errors'] += 1
        return False

