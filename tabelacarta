(function() {
  // Remove botão antigo se já existir
  let oldBtn = document.getElementById('ecarta-copiar-btn');
  if (oldBtn) oldBtn.remove();
  
  // Remove menu de documento antigo se existir
  let oldMenu = document.getElementById('doc-menu');
  if (oldMenu) oldMenu.remove();  // Cria botão flutuante
  const btn = document.createElement('button');
  btn.id = 'ecarta-copiar-btn';
  btn.textContent = 'Copiar eCarta';
  Object.assign(btn.style, {
    position: 'fixed',
    bottom: '30px',
    right: '30px',
    zIndex: 9999,
    padding: '12px 20px',
    background: '#1976d2',
    color: '#fff',
    border: 'none',
    borderRadius: '8px',
    fontSize: '16px',
    boxShadow: '0 2px 8px rgba(0,0,0,0.2)',
    cursor: 'pointer',
    transition: 'background 0.2s'
  });  btn.onmouseenter = () => btn.style.background = '#1565c0';
  btn.onmouseleave = () => btn.style.background = '#1976d2';
  document.body.appendChild(btn);

  // ===== FUNÇÃO AUXILIAR: CRIAR URL DO DOCUMENTO =====
  function criarUrlDocumento(documentoId) {
    const baseUrl = window.location.origin;
    const currentPath = window.location.pathname;
    
    // Detecta o contexto do PJe baseado na URL atual
    let contexto = '';
    if (currentPath.includes('/pjekz/')) {
      contexto = '/pjekz';
    } else if (currentPath.includes('/pje/')) {
      contexto = '/pje';
    } else {
      contexto = '/pjekz'; // Padrão mais comum
    }
    
    // URLs baseadas nos padrões encontrados no AVJT e MaisPje
    if (contexto === '/pjekz') {
      return `${baseUrl}/pjekz/processo/documento/${documentoId}/conteudo`;
    } else {
      return `${baseUrl}/pje/Processo/ConsultaDocumento/Documento.seam?doc=${documentoId}`;
    }
  }

  // ===== FUNCIONALIDADE ORIGINAL: COPIAR ECARTA =====
  function gerarTabela() {
    // 1. Seleciona as linhas da tabela
    const rows = Array.from(document.querySelectorAll('#main\\:tabDoc_data tr'));
    if (!rows.length) { 
      alert('Tabela não encontrada!'); 
      return null; 
    }
      // 2. Extrai os dados das linhas
    const data = rows.map(tr => {
      const tds = tr.querySelectorAll('td');
      const objetoTd = tds[4];
      let objeto = objetoTd?.innerText.trim() || '';      let objetoLink = null;      
        // Extrai ID (coluna 3) - transforma em link clicável para abrir documento
      const idTd = tds[3];
      let idPje = idTd?.innerText.trim() || '';
      let idPjeLink = null;
      
      // Se encontrou um ID válido (numérico de 10+ dígitos), cria link para o documento
      if (idPje && /^\d{10,}$/.test(idPje)) {
        idPjeLink = criarUrlDocumento(idPje);
        console.log('Link de documento criado para ID:', idPje, 'URL:', idPjeLink);
      }// Extrai código de rastreamento (coluna 4)
      // Corrigindo: procura pelo span com ID de rastreamento e pega o link pai
      const spanElement = objetoTd?.querySelector('span[id*=":rastreamento"]');
      console.log('Span encontrado:', spanElement);
      
      if (spanElement) {
        const codigoRastreamento = spanElement.innerText.trim();
        console.log('Código encontrado:', codigoRastreamento);
        if (codigoRastreamento && codigoRastreamento.length > 5) {
          objeto = codigoRastreamento;
          // Pega o link pai do span
          const linkElement = spanElement.closest('a');
          if (linkElement && linkElement.href) {
            // Se for URL relativa, monta a URL completa
            if (linkElement.href.startsWith('/')) {
              objetoLink = `https://aplicacoes1.trt2.jus.br${linkElement.href}`;
            } else {
              objetoLink = linkElement.href;
            }
            console.log('Link criado:', objetoLink);
          }
        }
      } else {
        // Se não encontrou span, mantém o texto original mas sem link
        console.log('Nenhum span de rastreamento encontrado para:', objeto);
      }        return {
        dataEnvio: tds[0]?.innerText.trim(),
        dataEntrega: tds[1]?.innerText.trim(),
        idPje: idPje,
        idPjeLink: idPjeLink,
        objeto: objeto,
        objetoLink: objetoLink,
        status: tds[5]?.innerText.trim(),
        destinatario: tds[6]?.innerText.trim(),
        orgaoJulgador: tds[7]?.innerText.trim()
      };
    });

    // 3. Filtra pela data de envio mais recente
    function parseDate(d) {
      const [dia, mes, ano] = d.split('/');
      return new Date(`${ano}-${mes}-${dia}`);
    }
    
    const maxDataEnvio = data
      .map(d => d.dataEnvio)
      .filter(d => /\d{2}\/\d{2}\/\d{4}/.test(d))
      .map(parseDate)
      .sort((a, b) => b - a)[0];

    const recentes = data.filter(d => {
      if (!/\d{2}\/\d{2}\/\d{4}/.test(d.dataEnvio)) return false;
      return parseDate(d.dataEnvio).getTime() === maxDataEnvio.getTime();
    });
    
    if (!recentes.length) { 
      alert('Nenhuma intimação encontrada na data mais recente!'); 
      return null; 
    }
    
    // 4. Gera estrutura simples sem tabela
    let conteudoHtml = '';
    let conteudoTexto = '';    recentes.forEach((d, idx) => {
      // Versão HTML com links clicáveis (usando <br> para quebras de linha)
      conteudoHtml += `ID: ${d.idPjeLink ? `<a href="${d.idPjeLink}" target="_blank">${d.idPje}</a>` : d.idPje}<br>
DESTINATÁRIO: ${d.destinatario}<br>
DATA DO ENVIO: ${d.dataEnvio}<br>
DATA DE ENTREGA: ${d.dataEntrega}<br>
RESULTADO: ${d.status}<br>
OBJETO: ${d.objetoLink ? `<a href="${d.objetoLink}" target="_blank">${d.objeto}</a>` : d.objeto}<br>
DEVOLVIDA? ( ) - Desmarcado significa ENTREGA CONFIRMADA.`;
      
      // Versão texto com URLs explícitas (usando \n para quebras de linha)
      conteudoTexto += `ID: ${d.idPje}${d.idPjeLink ? `\n🔗 Link do documento: ${d.idPjeLink}` : ''}
DESTINATÁRIO: ${d.destinatario}
DATA DO ENVIO: ${d.dataEnvio}
DATA DE ENTREGA: ${d.dataEntrega}
RESULTADO: ${d.status}
OBJETO: ${d.objeto}${d.objetoLink ? `\n🔗 Link: ${d.objetoLink}` : ''}
DEVOLVIDA? ( ) - Desmarcado significa ENTREGA CONFIRMADA.`;      // Adiciona separador entre registros (exceto no último)
      if (idx < recentes.length - 1) {
        conteudoHtml += `<br><br>_____________________________________________________________<br><br>`;
        conteudoTexto += `\n\n_____________________________________________________________\n\n`;
      }
    });
    
    return { html: conteudoHtml, texto: conteudoTexto };
  }  // 5. Ação do botão: copiar com fallback robusto
  btn.onclick = async () => {
    try {
      const conteudo = gerarTabela();
      if (!conteudo) return;
      
      console.log('Tentando copiar conteúdo...');
      console.log('HTML gerado:', conteudo.html);
      console.log('Texto gerado:', conteudo.texto);
      
      let sucessoCopia = false;
      
      // Tentativa 1: Clipboard API moderna com HTML
      try {
        const htmlBlob = new Blob([conteudo.html], { type: 'text/html' });
        const textBlob = new Blob([conteudo.texto], { type: 'text/plain' });
        
        await navigator.clipboard.write([
          new ClipboardItem({
            'text/html': htmlBlob,
            'text/plain': textBlob
          })
        ]);
        
        btn.textContent = 'Copiado com links!';
        sucessoCopia = true;
        console.log('Sucesso: Clipboard API moderna');
      } catch (error1) {
        console.log('Falha Clipboard API moderna:', error1);
        
        // Tentativa 2: Clipboard API simples (só texto)
        try {
          await navigator.clipboard.writeText(conteudo.texto);
          btn.textContent = 'Copiado (texto)!';
          sucessoCopia = true;
          console.log('Sucesso: Clipboard API texto simples');
        } catch (error2) {
          console.log('Falha Clipboard API texto:', error2);
          
          // Tentativa 3: Método clássico (execCommand)
          try {
            const textarea = document.createElement('textarea');
            textarea.value = conteudo.texto;
            textarea.style.position = 'fixed';
            textarea.style.opacity = '0';
            document.body.appendChild(textarea);
            textarea.select();
            document.execCommand('copy');
            document.body.removeChild(textarea);
            
            btn.textContent = 'Copiado (clássico)!';
            sucessoCopia = true;
            console.log('Sucesso: execCommand');
          } catch (error3) {
            console.log('Falha execCommand:', error3);
            btn.textContent = 'Erro na cópia!';
            alert('Erro ao copiar. Tente novamente ou copie manualmente do console.');
          }
        }
      }
      
      if (sucessoCopia) {
        btn.style.background = '#43a047';
        
        setTimeout(() => {
          btn.textContent = 'Copiar eCarta';
          btn.style.background = '#1976d2';
        }, 2000);
      }
      
    } catch (error) {
      console.error('Erro geral:', error);
      btn.textContent = 'Erro!';
      btn.style.background = '#d32f2f';
      
      setTimeout(() => {
        btn.textContent = 'Copiar eCarta';
        btn.style.background = '#1976d2';
      }, 2000);
    }
  };
})();