{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(*)",
      "PowerShell(*)",
      "Edit(*)",
      "Write(*)",
      "Read(*)",
      "WebSearch(*)",
      "Skill(*)",
      "mcp__ide__getDiagnostics"
    ],
    "deny": []
  },
  "defaultMode": "acceptEdits",
  "effortLevel": "medium",
  "showThinkingSummaries": false,
  "showTurnDuration": true,
  "spinnerTipsEnabled": false,
  "autoMemoryEnabled": true,
  "cleanupPeriodDays": 7,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PROJECT_DIR}\\.claude\\hooks\\prevent-redundant-read.ps1\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolBatch": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PROJECT_DIR}\\.claude\\hooks\\enforce-consolidation.ps1\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}