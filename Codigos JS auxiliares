/**
 * Workflow completo para análise de processos no PJE
 */
async function workflow() {
    try {
        // Remover chips
        document.querySelector('#menu-do-processo-expandido-remover-chips')?.click();
        await new Promise(r => setTimeout(r, 2000));

        // Criar chip "Analisar"
        document.querySelector('.fa-plus')?.click();
        await new Promise(r => setTimeout(r, 2000));
        document.querySelector('#mat-checkbox-12-input')?.click();
        document.querySelector('.container-botoes > button:nth-child(1)')?.click();
        await new Promise(r => setTimeout(r, 1500));

        // Abrir documento e extrair conteúdo
        document.querySelector('.fa-file-code')?.click();
        await new Promise(r => setTimeout(r, 3000));
        const preview = document.querySelector('#previewModeloDocumento');
        if (!preview) throw new Error('Documento ativo não encontrado');
        const texto = preview.textContent?.toLowerCase() || '';
        const conteudo = texto.match(/servidor\s+respons[aá]vel/i)
            ? texto.substring(texto.indexOf('servidor responsável') + 20).trim()
            : texto.trim();

        console.log("Conteúdo extraído:", conteudo);

        // Fechar visualização
        document.querySelector('.div-preview-botoes > div:nth-child(1) > button:nth-child(1)')?.click();
        await new Promise(r => setTimeout(r, 1500));

        // Analisar conteúdo e criar GIGS
        await analisarConteudo(conteudo);
    } catch (e) {
        console.error('Erro no workflow:', e.message);
    }
}

/**
 * Analisa o conteúdo do documento e executa ações específicas
 */
async function analisarConteudo(conteudo) {
    if (!conteudo) return await criarGigs("SILAS - Prazo Manual", "0");
    console.log("Analisando conteúdo...");

    if (conteudo.includes("determinações necessárias para realização de hasta"))
        return await criarGigs("xs - hasta");
    if (conteudo.includes("ficando a reclamada ciente quanto ao saldo devedor remanescente"))
        return await criarGigs("xs - parcela");
    if (conteudo.includes("reconhecimento da prescrição intercorrente"))
        return await criarGigs("xs - arquivamento");
    if (conteudo.includes("ê-se visibilidade apenas aos advogados habilitados"))
        return await criarGigs("Guilherme – conf sobrest", "0");
    if (conteudo.includes("início da fluência do prazo prescricional"))
        return await criarGigs("Guilherme conf sobrest", "0");
    if (conteudo.includes("indicar meios para o prosseguimento da execução"))
        return await criarGigs("Guilherme conf sobrest", "0");
    if (conteudo.includes("revel"))
        return await criarGigs("Silvia - Homologação");
    if (conteudo.includes("expeçam-se ofícios requisitórios"))
        return await criarGigs("Bruna - RPV");
    if (conteudo.includes("se concorda com a homologação"))
        return await criarGigs("SILVIA - Homologação");

    return await criarGigs("SILAS - Prazo Manual", "0");
}

/**
 * Cria um GIGS com os parâmetros específicos
 */
async function criarGigs(txt, prazo = "1") {
    try {
        console.log(`Criando GIGS: ${txt} (Prazo: ${prazo})`);

        // Abrir modal
        document.querySelector('#nova-atividade')?.click();
        await new Promise(r => setTimeout(r, 2000));

        // Preencher Dias Úteis
        const campoDias = Array.from(document.querySelectorAll('label'))
            .find(l => l.textContent.includes('Dias Úteis'))
            ?.closest('mat-form-field')
            ?.querySelector('input');
        if (campoDias) {
            campoDias.value = prazo;
            campoDias.dispatchEvent(new Event('input', { bubbles: true }));
            campoDias.dispatchEvent(new Event('change', { bubbles: true }));
        } else {
            throw new Error("Campo Dias Úteis não encontrado");
        }

        // Preencher Observação
        const campoObs = Array.from(document.querySelectorAll('label'))
            .find(l => l.textContent.includes('Observação'))
            ?.closest('mat-form-field')
            ?.querySelector('textarea');
        if (campoObs) {
            campoObs.value = txt;
            campoObs.dispatchEvent(new Event('input', { bubbles: true }));
            campoObs.dispatchEvent(new Event('change', { bubbles: true }));
        } else {
            throw new Error("Campo Observação não encontrado");
        }

        // Clicar no botão Salvar
        const btnSalvar = Array.from(document.querySelectorAll('button'))
            .find(btn => btn.textContent.trim() === 'Salvar');
        if (btnSalvar) {
            btnSalvar.click();
            await new Promise(r => setTimeout(r, 1500));
            console.log("GIGS criado com sucesso:", txt);
        } else {
            throw new Error("Botão Salvar não encontrado");
        }
    } catch (e) {
        console.error('Erro ao criar GIGS:', e.message);
    }
}

// Executar workflow
workflow();

