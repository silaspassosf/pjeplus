{
  "manifest_version": 2,
  "name": "maisPJe",
  "version": "4.17.1",
  "description": "Extens\u00e3o complementar para o PJe (Processo Judicial Eletr\u00f4nico) que permite ao usu\u00e1rio gerenciar o ambiente de trabalho dentro do sistema, automatizando tarefas e eliminando as a\u00e7\u00f5es repetitivas do seu dia-a-dia.",
  "author": "Fernando de Medeiros Marcon",
  "browser_specific_settings": {
    "gecko": {
      "id": "{ab473c1e-2002-4db8-b85d-50dab45806b5}",
      "update_url": "https://www.trt12.jus.br/repo/maispje/Downloads/update.json"
    }
  },
  "icons": {
    "16": "icons/ico_16.png",
    "32": "icons/ico_32.png",
    "64": "icons/ico_64.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "comum/apis.js",
        "comum/storage.js",
        "comum/mini-selenium.js",
        "comum/botoes-atalhos.js",
        "comum/conciliajt.js",
        "iniciar.js"
      ],
      "run_at": "document_end"
    }
  ],
  "background": {
    "scripts": [
      "comum/storage.js",
      "gigs-background.js"
    ]
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true,
    "browser_style": true
  },
  "permissions": [
    "<all_urls>",
    "webRequest",
    "storage",
    "menus",
    "activeTab",
    "contextMenus",
    "notifications",
    "clipboardWrite"
  ],
  "browser_action": {
    "default_icon": {
      "16": "icons/ico_16.png",
      "32": "icons/ico_32.png",
      "64": "icons/ico_64.png"
    },
    "default_title": "maisPJe: Atalho r\u00e1pido",
    "default_popup": "icon_options.html",
    "browser_style": true
  }
}