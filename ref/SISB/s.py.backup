# ===================== WRAPPER PARA TIME.SLEEP COM DELAYS NOMEADOS =====================
import time as _time_module
_original_sleep = _time_module.sleep

# Armazena configurações de delays
_DELAY_CONFIG = {
    'default': 0.5,
    'form_fill': 1.0,
    'navigation': 3.0,
    'click': 0.3,
}

def time_sleep(delay_name='default', base_delay=None):
    """
    Wrapper para time.sleep() que aceita nomes de delays e base_delay customizável.
    
    Args:
        delay_name: Nome do delay predefinido ('default', 'form_fill', 'navigation', 'click')
        base_delay: Valor customizado em segundos (sobrescreve delay_name se fornecido)
    
    Exemplo:
        time_sleep('form_fill')  # Usa delay padrão de form_fill
        time_sleep('default', base_delay=2.0)  # Usa 2.0 segundos
        time_sleep(base_delay=1.5)  # Usa 1.5 segundos com delay_name='default'
    """
    if base_delay is not None:
        _original_sleep(base_delay)
    else:
        delay_value = _DELAY_CONFIG.get(delay_name, _DELAY_CONFIG['default'])
        _original_sleep(delay_value)

# Substituir time.sleep por time_sleep globalmente no módulo
time.sleep = time_sleep
