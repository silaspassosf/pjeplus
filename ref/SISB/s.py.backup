def trigger_event(elemento, event_type):
    """Simula triggerEvent do gigs.js"""
    driver = elemento.parent
    driver.execute_script(f"arguments[0].dispatchEvent(new Event('{event_type}', {{bubbles: true}}));", elemento)


def aguardar_elemento(driver, seletor, texto=None, timeout=10):
    """
    Aguarda elemento aparecer usando MutationObserver (como gigs.py) - OTIMIZADO
    """
    script_aguardar = f"""
    function esperarElemento(seletor, timeout = {timeout * 1000}) {{
        return new Promise(resolve => {{
            let elemento = document.querySelector(seletor);
            let disabled = (elemento && elemento.disabled === undefined) ? false : elemento.disabled;
            if (elemento && !disabled) {{
                resolve(elemento);
                return;
            }} else {{
                let observer = new MutationObserver(mutations => {{
                    let elemento_esperado = document.querySelector(seletor);
                    let disabled = (elemento_esperado && elemento_esperado.disabled === undefined) ? false : elemento_esperado.disabled;
                    if (elemento_esperado && !disabled) {{
                        observer.disconnect();
                        resolve(elemento_esperado);
                        return;
                    }}
                }});
                
                observer.observe(document.body, {{ childList: true, subtree: true }});
                setTimeout(function() {{ 
                    observer.disconnect(); 
                    resolve(null); 
                }}, timeout);
            }}
        }});
    }}
    
    return esperarElemento('{seletor}').then(el => el ? true : false);
    """
    
    try:
        # Executa JavaScript otimizado (sem polling)
        encontrado = driver.execute_script(script_aguardar)
        if encontrado:
            # Re-localiza elemento via Selenium apenas se encontrado
            if texto:
                element = driver.find_element(By.XPATH, f"//*[contains(text(), '{texto}')]")
            else:
                element = driver.find_element(By.CSS_SELECTOR, seletor)
            
            # Simular movimento humano para o elemento
            simulate_human_movement(driver, element)
            return element
        else:
            return None
        
    except Exception as e:
        print(f'[SISBAJUD] ⚠️ Elemento não encontrado ({seletor}): {e}')
        SISBAJUD_STATS['consecutive_errors'] += 1
        return None


def aguardar_e_clicar(driver, seletor, texto=None, timeout=10):
    """
    Aguarda e clica em elemento com segurança (equivalente ao clicarBotao do gigs.js)
    """
    elemento = aguardar_elemento(driver, seletor, texto, timeout)
    if elemento:
        return safe_click(driver, elemento, 'click')
    return False


def aguardar_opcoes_aparecerem(driver, seletor_opcoes, intervalo_ms=50, max_tentativas=30):
    """
    Aguarda opções aparecerem usando MutationObserver (OTIMIZADO) - SEM POLLING
    """
    script_aguardar_opcoes = f"""
    function aguardarOpcoes(seletor, timeout = 5000) {{
        return new Promise(resolve => {{
            let opcoes = document.querySelectorAll(seletor);
            if (opcoes.length > 0) {{
                resolve(opcoes.length);
                return;
            }}
            
            let observer = new MutationObserver(mutations => {{
                let opcoes_encontradas = document.querySelectorAll(seletor);
                if (opcoes_encontradas.length > 0) {{
                    observer.disconnect();
                    resolve(opcoes_encontradas.length);
                    return;
                }}
            }});
            
            observer.observe(document.body, {{ childList: true, subtree: true }});
            setTimeout(function() {{ 
                observer.disconnect(); 
                resolve(0); 
            }}, timeout);
        }});
    }}
    
    return aguardarOpcoes('{seletor_opcoes}');
    """
    
    try:
        # Executa JavaScript otimizado (SEM POLLING)
        num_opcoes = driver.execute_script(script_aguardar_opcoes)
        
        if num_opcoes > 0:
            # Re-localiza via Selenium apenas após confirmação
            opcoes = driver.find_elements(By.CSS_SELECTOR, seletor_opcoes)
            print(f'[SISBAJUD] ✅ Encontradas {len(opcoes)} opções (MutationObserver)')
            return opcoes
        else:
            print(f'[SISBAJUD] ⚠️ Opções não encontradas (MutationObserver timeout)')
            return []
        return []
        
    except Exception as e:
        print(f'[SISBAJUD] ❌ Erro em aguardar_opcoes_aparecerem: {e}')
        return []

